{
  "name": "constellagent",
  "productName": "Constellagent",
  "version": "1.0.0",
  "description": "Mac app for running multiple AI agents in parallel",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/electron-vite-build.mjs",
    "preview": "electron-vite preview",
    "test": "bunx playwright test --project=electron",
    "test:automations": "bun run scripts/automations-smoke.ts",
    "test:automations:e2e": "bunx playwright test e2e/automations.spec.ts --project=electron",
    "test:review:e2e": "bunx playwright test e2e/hunk-review.spec.ts --project=electron",
    "verify:automations": "bash scripts/verify-automations.sh",
    "rebuild": "bunx electron-rebuild",
    "dist": "node scripts/electron-vite-build.mjs && electron-builder --mac --arm64",
    "postinstall": "bash scripts/patch-electron-dev.sh && bunx electron-rebuild"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@monaco-editor/react": "^4.7.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@pierre/diffs": "^1.1.11",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tridha643/review-annotations": "workspace:*",
    "@types/diff": "^8.0.0",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "agentfs-sdk": "^0.6.0",
    "ai": "^6.0.146",
    "allotment": "^1.20.5",
    "cachebro": "^0.2.0",
    "diff": "^8.0.3",
    "electron-vite": "^5.0.0",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.45",
    "monaco-editor": "^0.55.1",
    "monaco-languageclient": "^10.7.0",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.2.4",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.2.2",
    "vscode-ws-jsonrpc": "^3.5.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  }
}
