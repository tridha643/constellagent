{
  "name": "pi-constell-tasks",
  "version": "0.1.0",
  "description": "Companion pi extension for native workspace tasks, manual /tasks control, and cross-instance implementation pickup.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "tasks",
    "constellagent"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owengretzinger/constellagent.git",
    "directory": "packages/pi-constell-tasks"
  },
  "files": [
    "extensions",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "../pi-constell/node_modules/.bin/tsc -p tsconfig.json --noEmit",
    "test": "../pi-constell/node_modules/.bin/tsx --test test/*.test.ts",
    "test:e2e": "../pi-constell/node_modules/.bin/tsx --test test/*.e2e.test.ts",
    "verify": "npm run typecheck && npm run test && npm run test:e2e",
    "manual:verify": "tsx scripts/manual-verify.ts",
    "verify:pi-cli": "tsx scripts/verify-pi-cli.ts",
    "prepublishOnly": "npm run verify"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-constell-tasks.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
