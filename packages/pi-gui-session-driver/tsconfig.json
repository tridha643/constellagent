{
  "extends": "../tsconfig.pi-gui.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "composite": false,
    "emitDeclarationOnly": false,
    "outDir": "dist",
    "rootDir": "src",
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
