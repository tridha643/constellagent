{
  "name": "@tridha643/review-annotations",
  "version": "0.1.0",
  "description": "libSQL-backed code review annotations — library + CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "constell-annotate": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsx --test src/index.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "review",
    "annotations",
    "diff",
    "git",
    "cli",
    "libsql",
    "sqlite",
    "constellagent"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owengretzinger/constellagent.git",
    "directory": "packages/review-annotations"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
