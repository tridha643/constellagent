{
  "name": "constellagent-root",
  "private": true,
  "workspaces": ["packages/*", "desktop"],
  "dependencies": {
    "katex": "^0.16.45"
  },
  "scripts": {
    "setup": "bun install && bun run --cwd desktop rebuild",
    "dev": "bun run --cwd desktop dev",
    "dev:isolated": "sh scripts/dev-isolated.sh",
    "dev-isolated": "sh scripts/dev-isolated.sh",
    "build": "bun run --cwd desktop build",
    "test": "bun run --cwd desktop test",
    "test:automations": "bun run --cwd desktop test:automations",
    "test:automations:e2e": "bun run --cwd desktop test:automations:e2e",
    "verify:automations": "bun run --cwd desktop verify:automations",
    "rebuild": "bun run --cwd desktop rebuild",
    "dist": "bun run --cwd desktop dist",
    "landing": "bunx serve landing-page"
  }
}
